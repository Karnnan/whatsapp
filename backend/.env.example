# --- Supabase ---
# From your Supabase project: Settings -> API
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
# Use the SERVICE ROLE key here (server-side only, never expose to the browser).
# It bypasses Row Level Security so the bot can read/write freely.
SUPABASE_SERVICE_KEY=your-service-role-key

# --- Server ---
PORT=4000
# The URL of the Next.js frontend, used for CORS.
FRONTEND_URL=http://localhost:3000

# --- Broadcast throttling (milliseconds) ---
# Random delay between broadcast messages to reduce spam-flag risk.
BROADCAST_MIN_DELAY=4000
BROADCAST_MAX_DELAY=9000
