# --- Supabase ---
# From your Supabase project: Settings -> API
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
# Use the SERVICE ROLE key here (server-side only, never expose to the browser).
# It bypasses Row Level Security so the bot can read/write freely.
SUPABASE_SERVICE_KEY=your-service-role-key

# --- Server ---
PORT=4000
# Allowed dashboard origin(s) for CORS. Comma-separate to allow more than one,
# e.g. a local dashboard AND a deployed one:
#   FRONTEND_URL=http://localhost:3000,https://your-site.netlify.app
FRONTEND_URL=http://localhost:3000

# --- Puppeteer (Docker / hosting only) ---
# Point whatsapp-web.js at a system-installed Chromium when hosting in Docker.
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# --- Broadcast throttling (milliseconds) ---
# Random delay between broadcast messages to reduce spam-flag risk.
BROADCAST_MIN_DELAY=4000
BROADCAST_MAX_DELAY=9000
